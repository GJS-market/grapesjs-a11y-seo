{
  "name": "grapesjs-a11y-seo",
  "version": "2.3.5",
  "description": "Lighthouse for GrapesJS — an in-editor accessibility auditor (WCAG 2.1/2.2) and SEO metadata manager. Every finding is bound to the exact component: click to select, scroll and quick-fix.",
  "main": "dist/index.js",
  "browser": "dist/index.js",
  "unpkg": "dist/index.js",
  "jsdelivr": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "grapesjs": {
    "global": "grapesjsA11ySeo",
    "browser": "dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "webpack.config.js",
    "tsconfig.json",
    "README.md",
    "DOCS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "grapesjs",
    "grapesjs-plugin",
    "accessibility",
    "web-accessibility",
    "a11y",
    "wcag",
    "wcag-2.2",
    "seo",
    "seo-tools",
    "audit",
    "contrast",
    "meta-tags",
    "json-ld",
    "sitemap",
    "open-graph"
  ],
  "author": "gjs.market",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://gjs.market",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GJS-market/grapesjs-a11y-seo.git"
  },
  "bugs": {
    "url": "https://github.com/GJS-market/grapesjs-a11y-seo/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite --open /demo/index.html",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && grapesjs-cli build --patch=false",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview:demo": "vite preview --config vite.demo.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepublishOnly": "npm run test && npm run build"
  },
  "peerDependencies": {
    "grapesjs": ">=0.21.0"
  },
  "devDependencies": {
    "@grapesjs/studio-sdk": "^1.1.1",
    "@playwright/test": "^1.49.1",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^2.1.9",
    "axe-core": "^4.10.2",
    "css-loader": "^7.1.4",
    "grapesjs": "^0.21.13",
    "grapesjs-cli": "^4.1.3",
    "jsdom": "^25.0.1",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^2.1.8"
  }
}
